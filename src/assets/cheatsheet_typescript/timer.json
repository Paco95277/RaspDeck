	{ "id": "b2", "title": "Define a (one-time)Timer", "icon": "📝", "action": { "type": "insert", "text": "private timer?: ReturnType<typeof setTimeout>;\n" } },
    { "id": "b3", "title": "Set Timer", "icon": "📝", "action": { "type": "insert", "text": "this.timer = setTimeout(() => {code}, <time value>);\n" } },
    { "id": "b4", "title": "Clear Timer", "icon": "📝", "action": { "type": "insert", "text": "clearTimeout(this.timer);\n" } },
    { "id": "b5", "title": "Define a (interval) Timer", "icon": "📝", "action": { "type": "insert", "text": "private interval?: ReturnType<typeof setInterval>;\n" } },
    { "id": "b6", "title": "Set Interval", "icon": "📝", "action": { "type": "insert", "text": "this.interval = setInterval(() => {code}, <interval value>);\n" } },
    { "id": "b7", "title": "Clear Interval", "icon": "📝", "action": { "type": "insert", "text": "clearInterval(this.interval);\n" } },
