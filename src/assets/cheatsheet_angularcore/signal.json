    { "id": "b1", "title": "Return", "icon": "◀", "action": {"type": "nav", "route": "/cheatsheet/angular/angularcore" } },
	{ "id": "b2", "title": "Import Signal", "icon": "📝", "action": { "type": "insert", "text": "import { signal, computed, effect } from '@angular/core';\n" } },
	{ "id": "b3", "title": "Define a Signal", "icon": "📝", "action": { "type": "insert", "text": "mySignal = signal<type>(<init value>);\n" } },
    { "id": "b4", "title": "Computed With Signal", "icon": "📝", "action": { "type": "insert", "text": "//Do not write a Signal in computed\ncalcMySignal = computed(() => {const s = mySignal() + 1; return s;});\n" } },
    { "id": "b5", "title": "Write a Signal", "icon": "📝", "action": { "type": "insert", "text": "mySignal.set(<value>);\n" } },
    { "id": "b6", "title": "Output a Signal", "icon": "📝", "action": { "type": "insert", "text": "console.log(mySignal());\n" } },
    { "id": "b7", "title": "Effect", "icon": "📝", "action": { "type": "insert", "text": "//Do the side effects here\neffect(() => {mySignal()});\n" } },
